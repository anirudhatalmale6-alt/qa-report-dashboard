        {
            "name": "Locust: Web UI Mode",
            "type": "debugpy",
            "request": "launch",
            "module": "locust",
            "args": [
                "-f", "${file}",
                "--env-name", "UAT75"
            ],
            "cwd": "${workspaceFolder}/locust",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Locust: CSV Stats Export",
            "type": "debugpy",
            "request": "launch",
            "module": "locust",
            "args": [
                "-f", "${file}",
                "--headless",
                "--users", "1",
                "--spawn-rate", "1",
                "--run-time", "120s",
                "--only-summary",
                "--env-name", "UAT75",
