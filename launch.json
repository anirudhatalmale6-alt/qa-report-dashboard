{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Locust: WSS RetiredMem (UAT75)",
            "type": "debugpy",
            "request": "launch",
            "module": "locust",
            "args": [
                "-f", "wss/WSS_Retiredmem.py",
                "--headless",
                "--users", "1",
                "--spawn-rate", "1",
                "--run-time", "60s",
                "--only-summary",
                "--env-name", "UAT75",
                "--csv", "locust-results/WSS_Retiredmem",
                "--logfile", "logs/WSS_Retiredmem.log"
            ],
            "cwd": "${workspaceFolder}/locust",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Locust: WSS RetiredMem AddDep (UAT41)",
